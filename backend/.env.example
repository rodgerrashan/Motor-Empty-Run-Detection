PORT=8080
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=motor_monitor
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_IDLE_MS=300000
MONGO_CONNECT_TIMEOUT_MS=8000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=edge_ai/motor_efficiency
MQTT_CLIENT_ID=backend-ingestor

MODEL_PATH=/app/mlModel/motor_fault_model.onnx
FEATURE_COLUMNS_PATH=/app/mlModel/feature_columns.json

TELEMETRY_TTL_SECONDS=2592000
ALERTS_TTL_SECONDS=7776000
EVAL_WINDOW_SIZE=120
EVAL_EMIT_EVERY=20
