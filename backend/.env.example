PORT=8080
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=motor_monitor
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_IDLE_MS=300000
MONGO_CONNECT_TIMEOUT_MS=8000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=edge_ai/motor_efficiency
MQTT_CLIENT_ID=backend-ingestor

MODEL_PATH=/app/mlModel/motor_fault_model.onnx
FEATURE_COLUMNS_PATH=/app/mlModel/feature_columns.json

TELEMETRY_TTL_SECONDS=2592000
ALERTS_TTL_SECONDS=7776000
EVAL_WINDOW_SIZE=120
EVAL_EMIT_EVERY=20

# Email Alert Configuration
# Enable/disable critical alert emails (true/false)
ALERT_EMAIL_ENABLED=true
# Admin email recipient for critical alerts
ALERT_ADMIN_EMAIL=e20242@eng.pdn.ac.lk
# Email throttle window in minutes (prevents duplicate alerts)
ALERT_EMAIL_THROTTLE_MINUTES=30

# SMTP Configuration (required if ALERT_EMAIL_ENABLED=true)
# SMTP server hostname
SMTP_HOST=smtp-relay.brevo.com
# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP login username
SMTP_USER=8b8de6001@smtp-brevo.com
# SMTP password or API key
SMTP_PASS=xsmtpsib-013370fe42264389d4353c77ba00137dd39ad35193ce3ad8c679fb6abb2d8918-G7tcb4JjntgbvoZs
# Sender email address (defaults to SMTP_USER if not set)
ALERT_FROM_EMAIL=8b8de6001@smtp-brevo.com

# Critical Alert Thresholds
# Temperature threshold in Celsius (triggers email alert)
CRITICAL_TEMPERATURE_C=100
# Vibration threshold in Hz (triggers email alert)
CRITICAL_VIBRATION_HZ=80
# Locked rotor: current threshold in Amps
CRITICAL_LOCKED_ROTOR_CURRENT_A=22
# Locked rotor: RPM threshold (triggers alert if current high AND rpm low)
CRITICAL_LOCKED_ROTOR_RPM=200

